<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  
  <title>{{#if seo.title}}{{seo.title}}{{else}}Dados Históricos - Eleições Brasil{{/if}}</title>
  <meta name="description" content="{{#if seo.description}}{{seo.description}}{{else}}Consulte os resultados oficiais e estatísticas de eleições passadas de forma detalhada.{{/if}}">

  <meta property="og:type" content="website">
  <meta property="og:title" content="{{#if seo.title}}{{seo.title}}{{else}}Dados Históricos - Eleições Brasil{{/if}}">
  <meta property="og:description" content="{{#if seo.description}}{{seo.description}}{{else}}Consulte os resultados oficiais e estatísticas de eleições passadas.{{/if}}">
  <meta property="og:url" content="{{#if seo.url}}{{seo.url}}{{else}}{{URL_SITE_BASE}}{{/if}}">
  <meta property="og:image" content="{{#if seo.image}}{{seo.image}}{{else}}{{URL_SITE_BASE}}/img/default-share.jpg{{/if}}">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">

  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{#if seo.title}}{{seo.title}}{{else}}Dados Históricos - Eleições Brasil{{/if}}">
  <meta name="twitter:description" content="{{#if seo.description}}{{seo.description}}{{else}}Consulte os resultados oficiais e estatísticas de eleições passadas.{{/if}}">
  <meta name="twitter:image" content="{{#if seo.image}}{{seo.image}}{{else}}{{URL_SITE_BASE}}/img/default-share.jpg{{/if}}">

  {{#if schema}}
  <script type="application/ld+json">
    {{{schema}}}
  </script>
  {{/if}}

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="bg-light">

  <div class="d-flex" id="wrapper">
    {{> sidebar }}

    <div id="page-content-wrapper" class="flex-grow-1 p-4">
      {{{body}}}
      {{> footer }}
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  <script type="module" src="/js/script.js"></script>
</body>
</html>
